# Supabase (optional -- app works in offline mode without these)
# Create a free project at https://supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only — bypass RLS for indexer back-fill writes. NEVER exposed to client.
SUPABASE_SERVICE_ROLE_KEY=

# WalletConnect Project ID (optional -- for WalletConnect support)
# Create a free project at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# AI Agent server keys (server-side only -- /api/agent/derive)
#
# Provider preference order:
#   PRIMARY:   NVIDIA Kimi K2 instruct (NVIDIA_API_KEY)
#   FALLBACK:  Anthropic Claude opus-4-6 (ANTHROPIC_API_KEY)
#
# Set at least ONE of NVIDIA_API_KEY / ANTHROPIC_API_KEY. AGENT_PRIVATE_KEY
# is always required (signs the on-chain attestation).
#
# Override the order via AGENT_PROVIDER_PREFERENCE=anthropic if you want
# Claude tried first instead of Kimi.
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
AGENT_PROVIDER_PREFERENCE=

# AGENT_PRIVATE_KEY: 0x-prefixed 64-char hex; the wallet that signs agent
#                    attestations on-chain. Publish AGENT_ADDRESS publicly
#                    via VITE_AGENT_ATTESTATION_ADDRESS so users can audit.
AGENT_PRIVATE_KEY=

# AA relayer (server-side only -- /api/relay)
# RELAYER_PRIVATE_KEY: 0x-prefixed 64-char hex; the wallet that submits
#                      UserOperations to EntryPoint. Needs ETH on every
#                      supported chain to pay submission gas. Refunded by
#                      the BlankPaymaster in feeToken (TestUSDC) — the
#                      paymaster's own ETH balance covers the gas in the
#                      meantime, refilled by an offline funding loop.
# SEPOLIA_RPC_URL / BASE_SEPOLIA_RPC_URL: per-chain RPC for the relayer
RELAYER_PRIVATE_KEY=
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# Frontend RPC URLs (optional — browser-exposed, prefix VITE_)
#
# Public testnet RPCs aggressively rate-limit under load, which makes the
# wagmi reads (balances, contract state) unreliable. Setting these points
# the frontend at a private RPC (Alchemy/QuickNode/Infura) whose provider
# supports *domain allowlisting* so the URL is safe to bundle into the client.
#
# If unset, the app falls back to a curated list of public RPCs with
# automatic failover (see src/lib/rpc.ts). Recommended for production — a
# single public RPC throttling you should not take the UI down.
VITE_SEPOLIA_RPC_URL=
VITE_BASE_SEPOLIA_RPC_URL=

# Public agent attestation address (frontend-exposed -- prefix VITE_)
# Address derived from AGENT_PRIVATE_KEY. Publish so users can audit which
# agent signed each AI-derived payment. Same value across all chains.
VITE_AGENT_ATTESTATION_ADDRESS=

# Frontend error tracking (optional). When set, Sentry captures errors +
# warnings logged via lib/log. Without it the app still works — logs
# stay in the browser console. Get a DSN at https://sentry.io
VITE_SENTRY_DSN=

# Server-side signer backend. "env" (default) reads keys from env vars.
# "kms" will fetch from AWS KMS — see docs/SIGNER_KMS_PLAN.md.
BLANK_SIGNER_BACKEND=

# When BLANK_SIGNER_BACKEND=kms, both must be set:
KMS_AGENT_KEY_ID=
KMS_RELAYER_KEY_ID=

# Set to any random hex string. Vercel Cron must include it in
# Authorization header; protects /api/cron/* from public abuse.
CRON_SECRET=
